# Copy to .env and fill these in, then: docker compose up -d
FLEET_NODE_NAME=my-node                                   # unique label + tailscale hostname
FLEET_CORE_URL=https://master.tail28a9b4.ts.net/fleet-api  # core's stable MagicDNS serve URL
FLEET_JOIN_KEY=fleet-dev-join-key                          # shared bootstrap enrolment secret
FLEET_TS_AUTHKEY=tskey-auth-REPLACE-ME                     # this node's Tailscale auth key (per-device)
FLEET_SUBNET=10.42.0.0/24                                  # this node's app subnet (unique per node — see the fleet Nodes view)
# BOOTSTRAP ONLY: the node pulls the agent image from Artifact Registry on the
# first `docker compose up`. Log in ONCE on the host with a READ-ONLY AR key
# (roles/artifactregistry.reader):
#   cat ar-readonly-key.json | docker login -u _json_key --password-stdin https://europe-central2-docker.pkg.dev
# After bootstrap you DON'T need this for upgrades — agent self-update is driven
# from the control plane ("Update agent" on the node row), which brokers a
# short-lived registry token to the agent. No watchtower, no stored node creds.
# (optional) override the agent image:
# FLEET_AGENT_IMAGE=europe-central2-docker.pkg.dev/theitemapp/theitemapp/fleet-agent:latest
# advanced (defaults are fine):
# FLEET_TS_IP=10.42.0.2
# FLEET_ROUTE_RANGES=100.64.0.0/10 10.42.0.0/16
# FLEET_COMPOSE_DIR=/abs/path/to/this/repo   # only if you run `docker compose` from elsewhere
